# Airflow Configuration
AIRFLOW_USER_USERNAME=admin
AIRFLOW_USER_PASSWORD=admin
AIRFLOW_SECRET_KEY=my-secret-key-change-in-prod

# Fernet key for encrypting passwords in Airflow connections
